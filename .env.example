APP_NAME=Agro Insight API
ENVIRONMENT=development
# APP_ENV=development
API_PORT=8000
AIRFLOW_PORT=18080

# Google Earth Engine runtime auth
GEE_AUTH_MODE=service_account
GEE_PROJECT_ID=your-gcp-project-id
GEE_SERVICE_ACCOUNT_EMAIL=service-account@your-gcp-project-id.iam.gserviceaccount.com
GEE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_PRIVATE_KEY\n-----END PRIVATE KEY-----\n
GEE_OAUTH_CLIENT_ID=oauth-client-id.apps.googleusercontent.com
GEE_OAUTH_CLIENT_SECRET=replace-with-oauth-client-secret
GEE_OAUTH_REFRESH_TOKEN=replace-with-oauth-refresh-token

# Optional. Blank/unset uses ENVIRONMENT or APP_ENV defaults in code.
GEE_AUTH_TEST_ENABLED=
